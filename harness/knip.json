{
  "$schema": "./node_modules/knip/schema.json",
  "include": [
    "files",
    "exports",
    "nsExports",
    "types",
    "nsTypes",
    "dependencies"
  ],
  "workspaces": {
    "frontend": {
      "entry": ["tests/**/*.spec.ts", "scripts/*.js", "public/scripts/*.js"]
    },
    "harness": {
      "entry": ["*.test.ts", "lighthouserc.cjs"],
      "ignoreDependencies": [
        "@axe-core/playwright",
        "@secretlint/secretlint-rule-preset-recommend",
        "ajv",
        "ajv-formats",
        "ajv-keywords",
        "lighthouse"
      ]
    }
  }
}

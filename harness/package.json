{
  "name": "harness",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "harness": "./harness.mjs"
  },
  "engines": {
    "node": "^22.22.0 || >=24.8.0",
    "pnpm": ">=10"
  },
  "scripts": {
    "format": "cd .. && prettier frontend/ harness/ --check --ignore-path harness/.prettierignore",
    "gate": "node harness.mjs gate",
    "harness": "node harness.mjs",
    "html": "cd .. && html-validate --config harness/.htmlvalidate.json \"**/*.html\"",
    "lint": "pnpm eslint && pnpm style && pnpm html",
    "eslint": "cd .. && eslint . --config harness/eslint.config.js --cache --cache-location . --max-warnings=0 --debug",
    "preflight": "node harness.mjs preflight",
    "style": "cd .. && stylelint \"frontend/**/*.css\" --config harness/stylelint.config.js --ignore-path harness/.stylelintignore --max-warnings=0 --allow-empty-input --formatter verbose",
    "test": "cd .. && vitest run --config harness/vitest.config.js --reporter=verbose",
    "test:file": "cd .. && vitest run --config harness/vitest.config.js --coverage=false --reporter=verbose",
    "coverage": "cd .. && vitest run --config harness/vitest.config.js --coverage --reporter=verbose",
    "e2e": "pnpm playwright test --config playwright.config.js",
    "setup:e2e": "playwright install --with-deps",
    "typecheck": "pnpm typecheck:harness && pnpm typecheck:project",
    "typecheck:frontend": "pnpm typecheck:project",
    "typecheck:harness": "tsc -p tsconfig.harness.json --noEmit",
    "typecheck:project": "cd .. && tsc -p harness/tsconfig.app.json --noEmit",
    "lint:design": "cd .. && designmd lint DESIGN.md"
  },
  "devDependencies": {
    "@axe-core/playwright": "latest",
    "@eslint/js": "latest",
    "@eslint/json": "latest",
    "@google/design.md": "latest",
    "@lhci/cli": "latest",
    "@playwright/test": "latest",
    "@secretlint/secretlint-rule-preset-recommend": "latest",
    "@stoplight/spectral-cli": "latest",
    "@types/node": "latest",
    "@vitest/coverage-v8": "latest",
    "ajv": "latest",
    "ajv-cli": "latest",
    "ajv-formats": "latest",
    "ajv-keywords": "latest",
    "cspell": "latest",
    "dependency-cruiser": "latest",
    "eslint": "latest",
    "eslint-config-prettier": "latest",
    "eslint-import-resolver-node": "latest",
    "eslint-plugin-import-x": "latest",
    "eslint-plugin-jsdoc": "latest",
    "eslint-plugin-n": "latest",
    "eslint-plugin-no-only-tests": "latest",
    "eslint-plugin-promise": "latest",
    "eslint-plugin-regexp": "latest",
    "eslint-plugin-security": "latest",
    "eslint-plugin-sonarjs": "latest",
    "eslint-plugin-unicorn": "latest",
    "fast-check": "latest",
    "globals": "latest",
    "html-validate": "latest",
    "jiti": "latest",
    "jsdom": "latest",
    "knip": "latest",
    "lighthouse": "latest",
    "pnpm": "latest",
    "prettier": "latest",
    "secretlint": "latest",
    "stylelint": "latest",
    "stylelint-config-standard": "latest",
    "stylelint-declaration-strict-value": "latest",
    "stylelint-media-use-custom-media": "latest",
    "stylelint-plugin-defensive-css": "latest",
    "tsx": "latest",
    "typescript": "5.x",
    "typescript-eslint": "latest",
    "vite": "latest",
    "vitest": "latest"
  }
}

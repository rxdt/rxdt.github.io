{
  "elements": [
    "html5",
    {
      "style": {
        "deprecated": "no inline stylesheets; use external CSS"
      }
    }
  ],
  "extends": ["html-validate:recommended", "html-validate:prettier"],
  "rules": {
    "deprecated-rule": "error",
    "svg-focusable": "error",
    "no-inline-style": "error",
    "no-inline-script": "error",
    "element-permitted-content": "error",
    "no-dup-id": "error",
    "attr-spacing": "error"
  }
}
